# Copy this file to .env and fill in ONE of the two keys below.

# --- Option A (FREE, recommended): Groq ---
# Get a free key at https://console.groq.com/keys (Google/GitHub sign-in, no credit card)
GROQ_API_KEY=

# --- Option B: OpenAI (paid) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Server port
PORT=4000
